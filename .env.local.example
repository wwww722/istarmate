# 本地版只需要这一个变量。

# 随便生成一个随机字符串即可，用于加密登录session。
# 可以打开 https://generate-secret.vercel.app/32 复制一段，或者随便敲一串字符。
NEXTAUTH_SECRET=replace-with-any-random-string

NEXTAUTH_URL=http://localhost:3000

# === AI 对话（SiliconFlow GLM）===
# 去 https://cloud.siliconflow.cn 控制台拿你自己的 API Key，不要把真实key提交到GitHub
SILICONFLOW_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
