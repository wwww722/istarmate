# === AI 模型 ===
# 你自己的 Anthropic API key，去 https://console.anthropic.com 申请
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# === NextAuth 基础配置 ===
# 随便生成一个随机字符串即可，用于加密session，命令: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-random-string
# 部署后改成你的真实域名，例如 https://istarmate-2026.vercel.app
NEXTAUTH_URL=http://localhost:3000

# === 谷歌登录 ===
# 去 https://console.cloud.google.com -> APIs & Services -> Credentials 创建 OAuth Client ID
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# === 苹果登录 ===
# 去 https://developer.apple.com -> Certificates, Identifiers & Profiles 创建 Service ID
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# === 微信登录 ===
# 去 https://open.weixin.qq.com 注册网站应用，拿到 AppID / AppSecret
# 注意：微信网页登录要求已备案的域名，且不支持 localhost 测试，需要部署到真实域名后才能调试
WECHAT_APP_ID=
WECHAT_APP_SECRET=
